# Relational Database URL (SQLite fallback for local dev)
DATABASE_URL=sqlite:///./main.db

# Telemetry store backend: "sqlite" (default, works out of the box) or "hbase"
TELEMETRY_BACKEND=sqlite
TELEMETRY_SQLITE_PATH=./telemetry.db

# AI / LLM Config
GEMINI_API_KEY=sdfsadfasdfasdfasdf
AI_MODEL=asdfasdfasdfasdfasdf

# Simulator defaults
SIM_TENANT_UID=demo-utility
SIM_DEVICE_COUNT=10
SIM_INTERVAL_SECONDS=45
SIM_RANDOMNESS=0.3

# Recommendation engine cadence
RECOMMENDATION_INTERVAL_SECONDS=360000
